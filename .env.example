# Ritual sovereign agent deploy ayarları. .env olarak kopyalayın ve düzenleyin.
# cp .env.example .env

# --- zincir (chain) ---
RPC_URL=https://rpc.ritualfoundation.org
CHAIN_ID=1979

# --- agent cüzdanına kilitlenecek miktar, wei cinsinden (0.015 RITUAL ≈ 1 uyanış) ---
DEPOSIT_WEI=15000000000000000

# --- harness tipi: 6 = ZeroClaw ---
CLI_TYPE=6

# --- Ritual'ın kendi LLM gateway'i: harici API key gerekmez ---
MODEL=zai-org/GLM-4.7-FP8

# --- agent'ın her uyanışta çalıştıracağı görev ve benzersiz isim ---
PROMPT="Say hello world"
SALT=kriptokurdu-agent-1
